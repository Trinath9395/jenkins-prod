pipeline {
    agent any 
    stages {
        stage ('checkout the code') {
            steps {
                echo 'check out code'
            }
        }
        stage ('build') {
            steps {
                echo 'This is build step!'
            }
        }
        stage ('push') {
            steps {
                echo 'This is push stage!'
            }
        }
        stage ('deploy') {
            steps {
                echo 'This is deploy stage!'
            }
        }
        stage ('Test') {
            steps {
                echo 'This is test stage'
            }
        }
    }
}